{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile document",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "DailyLog": {
      "title": "Daily Log",
      "description": "User's daily tracking of their plan",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "shiftType": { "type": "string" },
        "waterLiters": { "type": "number" },
        "mealsCompleted": { "type": "number" },
        "workoutCompleted": { "type": "boolean" },
        "supplementsCompleted": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "date", "shiftType", "waterLiters", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/users/{userId}/dailyLogs/{logId}": {
      "schema": { "$ref": "#/entities/DailyLog" },
      "description": "User tracking logs"
    }
  }
}
